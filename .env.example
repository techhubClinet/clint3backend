# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB (MongoDB Atlas recommended for production)
MONGODB_URI=mongodb://127.0.0.1:27017/creative_ops

# JWT — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Single admin account (used by seed script — run once)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-secure-password-here

# Cloudinary (media + optional backup uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: folder prefix for uploads
CLOUDINARY_UPLOAD_FOLDER=creative-ops

# Scheduled JSON backup to Cloudinary (requires Cloudinary vars above)
ENABLE_SCHEDULED_BACKUPS=true
BACKUP_CRON=0 3 * * *
BACKUP_TIMEZONE=UTC
